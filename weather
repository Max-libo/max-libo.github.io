<!DOCTYPE html>

<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WHAT TO WEAR — Weather Outfit Advisor</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600;700&display=swap');

:root {
–bg: #0a0a0f;
–grid: rgba(0,120,255,0.07);
–blue: #0078ff;
–blue-dim: rgba(0,120,255,0.3);
–blue-bright: #4db8ff;
–text: #c8d8f0;
–text-dim: #4a6080;
–accent: #00e5ff;
–warn: #ff6b35;
–mono: ‘Share Tech Mono’, monospace;
–sans: ‘Rajdhani’, sans-serif;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: var(–mono);
min-height: 100vh;
overflow-x: hidden;
position: relative;
}

/* Blueprint grid */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image:
linear-gradient(var(–grid) 1px, transparent 1px),
linear-gradient(90deg, var(–grid) 1px, transparent 1px);
background-size: 40px 40px;
pointer-events: none;
z-index: 0;
}

/* Radial glow */
body::after {
content: ‘’;
position: fixed;
top: -20%;
left: 50%;
transform: translateX(-50%);
width: 80vw;
height: 60vh;
background: radial-gradient(ellipse, rgba(0,120,255,0.06) 0%, transparent 70%);
pointer-events: none;
z-index: 0;
}

.container {
position: relative;
z-index: 1;
max-width: 720px;
margin: 0 auto;
padding: 40px 24px 80px;
}

/* Header */
header {
border-bottom: 1px solid var(–blue-dim);
padding-bottom: 24px;
margin-bottom: 40px;
}

.header-label {
font-size: 10px;
letter-spacing: 0.3em;
color: var(–text-dim);
text-transform: uppercase;
margin-bottom: 8px;
}

h1 {
font-family: var(–sans);
font-size: clamp(32px, 8vw, 56px);
font-weight: 700;
letter-spacing: 0.05em;
color: #fff;
line-height: 1;
text-transform: uppercase;
}

h1 span {
color: var(–blue);
}

.header-sub {
font-size: 11px;
color: var(–text-dim);
letter-spacing: 0.15em;
margin-top: 8px;
}

/* Location block */
.location-block {
display: flex;
gap: 12px;
align-items: flex-end;
margin-bottom: 32px;
flex-wrap: wrap;
}

.input-group {
flex: 1;
min-width: 200px;
}

.input-label {
font-size: 10px;
letter-spacing: 0.25em;
color: var(–text-dim);
text-transform: uppercase;
margin-bottom: 6px;
display: block;
}

input[type=“text”] {
width: 100%;
background: rgba(0,120,255,0.05);
border: 1px solid var(–blue-dim);
color: var(–text);
font-family: var(–mono);
font-size: 14px;
padding: 10px 14px;
outline: none;
transition: border-color 0.2s, background 0.2s;
}

input[type=“text”]:focus {
border-color: var(–blue);
background: rgba(0,120,255,0.1);
}

input[type=“text”]::placeholder {
color: var(–text-dim);
}

.btn {
background: transparent;
border: 1px solid var(–blue);
color: var(–blue-bright);
font-family: var(–mono);
font-size: 12px;
letter-spacing: 0.15em;
padding: 10px 20px;
cursor: pointer;
text-transform: uppercase;
transition: background 0.2s, color 0.2s;
white-space: nowrap;
}

.btn:hover {
background: var(–blue);
color: #000;
}

.btn-geo {
border-color: var(–text-dim);
color: var(–text-dim);
font-size: 11px;
}

.btn-geo:hover {
border-color: var(–accent);
color: var(–accent);
background: transparent;
}

/* Status / error */
.status {
font-size: 11px;
letter-spacing: 0.1em;
color: var(–text-dim);
margin-bottom: 24px;
min-height: 16px;
}

.status.error { color: var(–warn); }
.status.loading { color: var(–blue-bright); }

/* Weather display */
.weather-panel {
border: 1px solid var(–blue-dim);
padding: 24px;
margin-bottom: 32px;
display: none;
position: relative;
}

.weather-panel::before {
content: ‘WEATHER DATA’;
position: absolute;
top: -1px;
left: 16px;
background: var(–bg);
font-size: 9px;
letter-spacing: 0.3em;
color: var(–blue);
padding: 0 8px;
transform: translateY(-50%);
}

.weather-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
gap: 20px;
}

.weather-stat {
display: flex;
flex-direction: column;
gap: 4px;
}

.weather-stat-label {
font-size: 9px;
letter-spacing: 0.25em;
color: var(–text-dim);
text-transform: uppercase;
}

.weather-stat-value {
font-family: var(–sans);
font-size: 28px;
font-weight: 600;
color: #fff;
line-height: 1;
}

.weather-stat-value .unit {
font-size: 14px;
color: var(–blue-bright);
font-weight: 300;
}

.weather-desc {
font-size: 12px;
color: var(–text-dim);
margin-top: 4px;
}

/* Outfit panel */
.outfit-panel {
border: 1px solid var(–blue-dim);
padding: 24px;
display: none;
position: relative;
animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
from { opacity: 0; transform: translateY(8px); }
to { opacity: 1; transform: translateY(0); }
}

.outfit-panel::before {
content: ‘OUTFIT RECOMMENDATION’;
position: absolute;
top: -1px;
left: 16px;
background: var(–bg);
font-size: 9px;
letter-spacing: 0.3em;
color: var(–accent);
padding: 0 8px;
transform: translateY(-50%);
}

.outfit-category {
margin-bottom: 20px;
}

.outfit-category:last-child {
margin-bottom: 0;
}

.outfit-cat-label {
font-size: 9px;
letter-spacing: 0.3em;
color: var(–text-dim);
text-transform: uppercase;
border-bottom: 1px solid rgba(0,120,255,0.15);
padding-bottom: 6px;
margin-bottom: 10px;
}

.outfit-items {
display: flex;
flex-direction: column;
gap: 6px;
}

.outfit-item {
font-size: 14px;
color: var(–text);
display: flex;
align-items: center;
gap: 10px;
}

.outfit-item::before {
content: ‘//’;
color: var(–blue);
font-size: 10px;
flex-shrink: 0;
}

.outfit-note {
margin-top: 20px;
padding: 12px 16px;
border-left: 2px solid var(–warn);
font-size: 12px;
color: var(–text-dim);
line-height: 1.6;
}

.outfit-note strong {
color: var(–warn);
font-weight: normal;
}

/* Footer */
footer {
margin-top: 60px;
border-top: 1px solid rgba(0,120,255,0.1);
padding-top: 20px;
font-size: 10px;
color: var(–text-dim);
letter-spacing: 0.1em;
display: flex;
justify-content: space-between;
flex-wrap: wrap;
gap: 8px;
}

footer a {
color: var(–blue-dim);
text-decoration: none;
letter-spacing: 0.05em;
}

footer a:hover { color: var(–blue); }

/* Loading dots */
.dots::after {
content: ‘’;
animation: dots 1.2s infinite;
}
@keyframes dots {
0%   { content: ‘.’; }
33%  { content: ‘..’; }
66%  { content: ‘…’; }
}
</style>

</head>
<body>
<div class="container">

  <header>
    <div class="header-label">// OUTFIT SYSTEM v1.0</div>
    <h1>WHAT TO <span>WEAR</span></h1>
    <div class="header-sub">WEATHER-BASED OUTFIT ADVISOR — OPEN-METEO API</div>
  </header>

  <div class="location-block">
    <div class="input-group">
      <label class="input-label" for="cityInput">// Город</label>
      <input type="text" id="cityInput" placeholder="Москва, Санкт-Петербург..." />
    </div>
    <button class="btn" onclick="getWeatherByCity()">ПРОВЕРИТЬ</button>
    <button class="btn btn-geo" onclick="getWeatherByGeo()">◎ ГЕО</button>
  </div>

  <div class="status" id="status"></div>

  <div class="weather-panel" id="weatherPanel">
    <div class="weather-grid">
      <div class="weather-stat">
        <span class="weather-stat-label">// Температура</span>
        <span class="weather-stat-value" id="wTemp">—<span class="unit">°C</span></span>
        <span class="weather-desc" id="wFeels"></span>
      </div>
      <div class="weather-stat">
        <span class="weather-stat-label">// Влажность</span>
        <span class="weather-stat-value" id="wHumid">—<span class="unit">%</span></span>
      </div>
      <div class="weather-stat">
        <span class="weather-stat-label">// Осадки</span>
        <span class="weather-stat-value" id="wRain">—<span class="unit">мм</span></span>
      </div>
      <div class="weather-stat">
        <span class="weather-stat-label">// Ветер</span>
        <span class="weather-stat-value" id="wWind">—<span class="unit">км/ч</span></span>
      </div>
    </div>
  </div>

  <div class="outfit-panel" id="outfitPanel">
    <div id="outfitContent"></div>
  </div>

  <footer>
    <span>// MAX-LIBO.GITHUB.IO</span>
    <span>ДАННЫЕ: OPEN-METEO.COM — <a href="https://open-meteo.com" target="_blank">OPEN SOURCE</a></span>
  </footer>
</div>

<script>
// ─── OUTFIT DATABASE ───────────────────────────────────────────────────────────
// Наборы одежды под разные условия.
// Логика: температура + ветер + осадки

function getOutfit(temp, feelsLike, rain, wind, humidity) {
  let top = [];
  let bottom = [];
  let shoes = [];
  let outer = [];
  let extras = [];
  let note = null;

  // ── ВЕРХ ──
  if (feelsLike >= 25) {
    top = ['Футболка или лёгкая рубашка'];
  } else if (feelsLike >= 18) {
    top = ['Футболка', 'Лёгкий лонгслив как вариант'];
  } else if (feelsLike >= 12) {
    top = ['Лонгслив или рубашка', 'Лёгкий свитер поверх'];
  } else if (feelsLike >= 5) {
    top = ['Термобельё или плотный свитер', 'Флис или толстовка'];
  } else {
    top = ['Термобельё (базовый слой)', 'Флис или толстый свитер (средний слой)'];
  }

  // ── НИЗ ──
  if (feelsLike >= 22) {
    bottom = ['Шорты или лёгкие брюки'];
  } else if (feelsLike >= 14) {
    bottom = ['Джинсы или хлопковые брюки'];
  } else if (feelsLike >= 5) {
    bottom = ['Плотные джинсы или утеплённые брюки'];
  } else {
    bottom = ['Термобельё под брюки', 'Плотные брюки или джинсы'];
  }

  // ── ВЕРХНЯЯ ОДЕЖДА ──
  if (feelsLike >= 22) {
    outer = [];
  } else if (feelsLike >= 16) {
    outer = ['Лёгкая ветровка или рубашка с длинным рукавом'];
  } else if (feelsLike >= 10) {
    outer = ['Демисезонная куртка или пальто'];
  } else if (feelsLike >= 2) {
    outer = ['Зимняя куртка или пуховик'];
  } else {
    outer = ['Тёплый пуховик или шуба'];
  }

  // ── ОБУВЬ ──
  if (rain > 0.5) {
    shoes = ['Водонепроницаемая обувь или ботинки'];
  } else if (feelsLike >= 20) {
    shoes = ['Кроссовки, сандалии или лёгкая обувь'];
  } else if (feelsLike >= 8) {
    shoes = ['Кроссовки или демисезонные ботинки'];
  } else {
    shoes = ['Утеплённые ботинки или зимние кроссовки'];
  }

  // ── АКСЕССУАРЫ ──
  if (rain > 1) extras.push('Зонт');
  if (rain > 0.1 && rain <= 1) extras.push('Складной зонт на всякий случай');
  if (feelsLike < 5) extras.push('Шапка');
  if (feelsLike < 2) extras.push('Шарф');
  if (feelsLike < -5) extras.push('Перчатки');
  if (wind > 30) extras.push('Ветрозащитный слой');
  if (feelsLike >= 20 && humidity < 40) extras.push('Солнечные очки');

  // ── ЗАМЕТКИ ──
  if (temp - feelsLike >= 5) {
    note = `<strong>// ВЕТЕР:</strong> Ощущается холоднее реального — ${temp}°C снаружи, но ощущается как ${feelsLike}°C. Одевайтесь по ощущаемой температуре.`;
  } else if (feelsLike >= 28) {
    note = `<strong>// ЖАРА:</strong> Лёгкая, дышащая одежда. Не забудьте воду.`;
  } else if (feelsLike <= -10) {
    note = `<strong>// МОРОЗ:</strong> Открытые участки кожи мёрзнут быстро. Закройте лицо и руки.`;
  }

  return { top, bottom, outer, shoes, extras, note };
}

// ─── RENDER ────────────────────────────────────────────────────────────────────
function renderOutfit(outfit) {
  let html = '';

  const sections = [
    { label: '// Верх', items: outfit.top },
    { label: '// Низ', items: outfit.bottom },
    { label: '// Верхняя одежда', items: outfit.outer },
    { label: '// Обувь', items: outfit.shoes },
    { label: '// Аксессуары', items: outfit.extras },
  ];

  for (const sec of sections) {
    if (sec.items.length === 0) continue;
    html += `<div class="outfit-category">
      <div class="outfit-cat-label">${sec.label}</div>
      <div class="outfit-items">
        ${sec.items.map(i => `<div class="outfit-item">${i}</div>`).join('')}
      </div>
    </div>`;
  }

  if (outfit.note) {
    html += `<div class="outfit-note">${outfit.note}</div>`;
  }

  document.getElementById('outfitContent').innerHTML = html;
  document.getElementById('outfitPanel').style.display = 'block';
}

// ─── WEATHER DISPLAY ───────────────────────────────────────────────────────────
function renderWeather(data) {
  const { temp, feelsLike, rain, wind, humidity } = data;

  document.getElementById('wTemp').innerHTML = `${Math.round(temp)}<span class="unit">°C</span>`;
  document.getElementById('wFeels').textContent = `Ощущается как ${Math.round(feelsLike)}°C`;
  document.getElementById('wHumid').innerHTML = `${humidity}<span class="unit">%</span>`;
  document.getElementById('wRain').innerHTML = `${rain.toFixed(1)}<span class="unit">мм</span>`;
  document.getElementById('wWind').innerHTML = `${Math.round(wind)}<span class="unit">км/ч</span>`;

  document.getElementById('weatherPanel').style.display = 'block';
}

// ─── OPEN-METEO FETCH ──────────────────────────────────────────────────────────
async function fetchWeather(lat, lon) {
  setStatus('Загрузка данных о погоде', 'loading');
  const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,apparent_temperature,precipitation,relative_humidity_2m,wind_speed_10m&timezone=auto`;

  const res = await fetch(url);
  if (!res.ok) throw new Error('Ошибка запроса погоды');
  const json = await res.json();
  const c = json.current;

  return {
    temp: c.temperature_2m,
    feelsLike: c.apparent_temperature,
    rain: c.precipitation,
    wind: c.wind_speed_10m,
    humidity: c.relative_humidity_2m,
  };
}

// ─── GEOCODING ─────────────────────────────────────────────────────────────────
async function geocodeCity(city) {
  const url = `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1&language=ru&format=json`;
  const res = await fetch(url);
  const json = await res.json();
  if (!json.results || json.results.length === 0) throw new Error('Город не найден');
  return { lat: json.results[0].latitude, lon: json.results[0].longitude, name: json.results[0].name };
}

// ─── ACTIONS ───────────────────────────────────────────────────────────────────
async function getWeatherByCity() {
  const city = document.getElementById('cityInput').value.trim();
  if (!city) { setStatus('Введите название города', 'error'); return; }

  try {
    setStatus('Поиск города', 'loading');
    const { lat, lon, name } = await geocodeCity(city);
    setStatus(`// ${name} — ${lat.toFixed(2)}, ${lon.toFixed(2)}`);
    const weather = await fetchWeather(lat, lon);
    renderWeather(weather);
    renderOutfit(getOutfit(weather.temp, weather.feelsLike, weather.rain, weather.wind, weather.humidity));
    setStatus(`// ДАННЫЕ АКТУАЛЬНЫ`);
  } catch (e) {
    setStatus(e.message, 'error');
  }
}

async function getWeatherByGeo() {
  if (!navigator.geolocation) { setStatus('Геолокация не поддерживается', 'error'); return; }
  setStatus('Определение геолокации', 'loading');

  navigator.geolocation.getCurrentPosition(async (pos) => {
    try {
      const weather = await fetchWeather(pos.coords.latitude, pos.coords.longitude);
      renderWeather(weather);
      renderOutfit(getOutfit(weather.temp, weather.feelsLike, weather.rain, weather.wind, weather.humidity));
      setStatus(`// ГЕО: ${pos.coords.latitude.toFixed(2)}, ${pos.coords.longitude.toFixed(2)}`);
    } catch(e) {
      setStatus(e.message, 'error');
    }
  }, () => {
    setStatus('Геолокация отклонена. Введите город вручную.', 'error');
  });
}

function setStatus(msg, type = '') {
  const el = document.getElementById('status');
  el.textContent = msg;
  el.className = 'status' + (type ? ' ' + type : '');
  if (type === 'loading') el.classList.add('dots');
}

// Enter key
document.getElementById('cityInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') getWeatherByCity();
});
</script>

</body>
</html>
